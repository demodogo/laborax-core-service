NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/platform_core
JWT_ACCESS_SECRET=change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-too
JWT_REFRESH_TTL=7d
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
SWAGGER_ENABLED=true
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
AUTH_THROTTLE_TTL_MS=60000
AUTH_THROTTLE_LIMIT=10
AUTH_MAX_ACTIVE_SESSIONS_PER_USER=5
SERVICE_CLIENT_SECRET_GRACE_PERIOD_MINUTES=60
SEED_PLATFORM_ADMIN_EMAIL=admin@laborax.local
SEED_PLATFORM_ADMIN_PASSWORD=Admin12345
SEED_PLATFORM_ADMIN_FIRST_NAME=Platform
SEED_PLATFORM_ADMIN_LAST_NAME=Admin

SEED_INTERNAL_JOBS_CLIENT_ID=internal-jobs-local
SEED_INTERNAL_JOBS_CLIENT_SECRET=change-me-internal-jobs

SEED_WORKFORCE_SERVICE_CLIENT_ID=workforce-local
SEED_WORKFORCE_SERVICE_CLIENT_SECRET=change-me-workforce-service

SEED_ACCESS_CONTROL_CLIENT_ID=access-control-local
SEED_ACCESS_CONTROL_CLIENT_SECRET=change-me-access-control

OUTBOX_PUBLISHER_ENABLED=false
EVENT_BUS_TRANSPORT=rabbitmq
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_EXCHANGE=laborax.domain-events
OUTBOX_POLL_INTERVAL_MS=5000
OUTBOX_BATCH_SIZE=25
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_RETRY_DELAY_MS=30000
