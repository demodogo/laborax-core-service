    {
      "name": "Internal Customer Onboarding",
      "item": [
        {
          "name": "POST /internal-customers",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.tenant && body.tenant.id) { pm.environment.set('tenantId', body.tenant.id); }",
                  "if (body.ownerCompany && body.ownerCompany.id) { pm.environment.set('companyId', body.ownerCompany.id); }",
                  "if (body.contract && body.contract.id) { pm.environment.set('contractId', body.contract.id); }",
                  "if (body.adminUser && body.adminUser.id) { pm.environment.set('userId', body.adminUser.id); }",
                  "if (body.adminUser && body.adminUser.email) { pm.environment.set('customerAdminEmail', body.adminUser.email); }",
                  "if (body.membership && body.membership.id) { pm.environment.set('membershipId', body.membership.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{platformCoreBaseUrl}}/internal-customers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{sampleCustomerName}}\",\n  \"companyRut\": \"{{sampleCompanyRut}}\",\n  \"companyLegalName\": \"{{sampleCompanyLegalName}}\",\n  \"companyTradeName\": \"{{sampleCompanyTradeName}}\",\n  \"contractNumber\": \"{{sampleContractNumber}}\",\n  \"contractStartDate\": \"2026-06-01\",\n  \"contractEndDate\": \"2027-06-01\",\n  \"contractNotes\": \"Onboarding creado desde Postman\",\n  \"adminEmail\": \"{{customerAdminEmail}}\",\n  \"adminFirstName\": \"Customer\",\n  \"adminLastName\": \"Admin\",\n  \"adminPassword\": \"{{customerAdminPassword}}\"\n}"
            },
            "description": "Alta profesional de cliente: crea tenant, OWNER company, contrato, admin cliente, membership, rol customer_admin y outbox events."
          }
        }
      ]
    },
