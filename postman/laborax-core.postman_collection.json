    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/login - Platform Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login ok', function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "if (body.accessToken) { pm.environment.set('accessToken', body.accessToken); }",
                  "if (body.refreshToken) { pm.environment.set('refreshToken', body.refreshToken); }",
                  "if (body.user && body.user.id) { pm.environment.set('currentUserId', body.user.id); }"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "url": "{{platformCoreBaseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "description": "Autentica admin global y guarda accessToken/refreshToken."
          }
        },
        {
          "name": "POST /auth/login - Customer Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login customer ok', function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "if (body.accessToken) { pm.environment.set('customerAccessToken', body.accessToken); }",
                  "if (body.refreshToken) { pm.environment.set('customerRefreshToken', body.refreshToken); }",
                  "if (body.user && body.user.id) { pm.environment.set('customerUserId', body.user.id); }"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "url": "{{platformCoreBaseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerAdminEmail}}\",\n  \"password\": \"{{customerAdminPassword}}\"\n}"
            },
            "description": "Autentica un admin cliente creado por onboarding y guarda tokens separados."
          }
        },
        {
          "name": "POST /auth/refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.accessToken) { pm.environment.set('accessToken', body.accessToken); }",
                  "if (body.refreshToken) { pm.environment.set('refreshToken', body.refreshToken); }"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "url": "{{platformCoreBaseUrl}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "description": "Renueva access/refresh token."
          }
        },
        {
          "name": "POST /auth/logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('logout ok', function () { pm.response.to.have.status(204); });",
                  "pm.environment.unset('accessToken');",
                  "pm.environment.unset('refreshToken');"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "url": "{{platformCoreBaseUrl}}/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "description": "Revoca la sesion asociada al refresh token. Responde 204 aunque el token ya no sea valido para mantener logout idempotente."
          }
        },
        {
          "name": "POST /auth/logout-all",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('logout all ok', function () { pm.response.to.have.status(204); });",
                  "pm.environment.unset('accessToken');",
                  "pm.environment.unset('refreshToken');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{platformCoreBaseUrl}}/auth/logout-all",
            "description": "Revoca todas las sesiones activas del usuario autenticado. Requiere access token vigente."
          }
        },
        {
          "name": "GET /auth/me",
          "request": {
            "method": "GET",
            "url": "{{platformCoreBaseUrl}}/auth/me",
            "description": "Perfil del usuario autenticado."
          }
        },
        {
